{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Make: Build",
            "type": "shell",
            "command": "make",
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Make: Test",
            "type": "shell",
            "command": "make test",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Make: Clean",
            "type": "shell",
            "command": "make clean",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake -S . -B build",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "CMake: Build Tests",
            "type": "shell",
            "command": "cmake --build build --config Debug --target test_factory",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "CMake: Build Tests (C)",
            "type": "shell",
            "command": "cmake --build build --config Debug --target test_factory_c",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "CMake: Run CTest",
            "type": "shell",
            "command": "ctest --test-dir build --output-on-failure",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\cygwin64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": { "kind": "build", "isDefault": false },
            "detail": "Task generated by Debugger."
        }
    ]
}