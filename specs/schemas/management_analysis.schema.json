{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "management_analysis",
  "type": "object",
  "properties": {
    "overall": {
      "type": "object",
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 5 },
        "label": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" } } } }
      }
    },
    "profile": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "tenure": { "type": "number" },
        "ownership_pct": { "type": "number" },
        "bio": { "type": "string" }
      }
    },
    "scorecards": {
      "type": "object",
      "properties": {
        "employee_sentiment": { "type": "object", "properties": { "scale": { "type": "string" }, "summary": { "type": "string" }, "details": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" } }, "required": ["title", "description"] }, "minItems": 3, "maxItems": 3 } } },
        "execution": { "type": "object", "properties": { "scale": { "type": "string" }, "summary": { "type": "string" }, "details": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" } }, "required": ["title", "description"] }, "minItems": 3, "maxItems": 3 } } },
        "shareholder_alignment": { "type": "object", "properties": { "scale": { "type": "string" }, "summary": { "type": "string" }, "details": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" } }, "required": ["title", "description"] }, "minItems": 3, "maxItems": 3 } } },
        "fcf_margins": { "type": "object", "properties": { "scale": { "type": "string" }, "summary": { "type": "string" }, "details": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" } }, "required": ["title", "description"] }, "minItems": 3, "maxItems": 3 } } }
      }
    }
  }
}
