{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "valuation_assessment",
  "type": "object",
  "properties": {
    "primary_multiple": { "type": "string" },
    "current_multiple": { "type": "number" },
    "historical_avg_5y": { "type": "number" },
    "nifty_sector_avg": { "type": "number" },
    "discount_premium_pct": { "type": "number" },
    "score": { "type": "number" },
    "label": { "type": "string", "enum": ["VERY EXPENSIVE", "EXPENSIVE", "FAIR VALUE", "ATTRACTIVE", "VERY ATTRACTIVE"] },
    "summary": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" } } } }
  },
  "required": ["current_multiple", "score", "label"]
}
